{
  "name": "aternos-unofficial-api",
  "version": "1.5.0",
  "description": "An unofficial API client to manage and interact with Aternos servers using Puppeteer.",
  "author": "Exocore",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=20.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ChoruOfficial/-Exocore-Aternos.git"
  },
  "social": {
    "github": "https://github.com/ChoruOfficial",
    "facebook": "https://www.facebook.com/share/19KrEB93gM/"
  },
  "scripts": {
    "start": "ts-node-dev --poll src/index.ts",
    "clean": "del-cli ./build/*",
    "build": "npm run clean && tsc"
  },
  "keywords": [
    "aternos",
    "minecraft",
    "bot",
    "api",
    "puppeteer",
    "exocore"
  ],
  "dependencies": {
    "axios": "1.13.5",
    "axios-cookiejar-support": "^4.0.7",
    "chalk": "^4.1.2",
    "cheerio": "^1.1.0",
    "devtools-protocol": "^0.0.1473885",
    "discord.js": "^14.25.1",
    "extract-zip": "^2.0.1",
    "form-data": "4.0.4",
    "freeport": "^1.0.5",
    "gradient-string": "^2.0.0",
    "proxy-chain": "^2.5.9",
    "puppeteer": "^24.38.0",
    "stable-chromium": "^127.0.0",
    "tough-cookie": "^5.1.2",
    "ts-node-dev": "^2.0.0",
    "del-cli": "^7.0.0"
  },
  "devDependencies": {
    "@types/freeport": "^1.0.24",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^24.0.1",
    "auto": "^11.1.1",
    "puppeteer": "^24.10.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.2.3",
    "typescript": "^5.8.3"
  }
}
